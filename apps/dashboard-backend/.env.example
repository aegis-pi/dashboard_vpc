# Dashboard Backend environment variables
# Copy to .env for local development — .env is git-ignored

DATABASE_URL=postgresql+asyncpg://aegis:changeme@localhost:5432/aegis_dashboard
REDIS_URL=redis://localhost:6379
REDIS_AUTH_TOKEN_SECRET_ARN=

DDB_TABLE_STATUS=AEGIS-DynamoDB-FactoryStatus
DDB_TABLE_REPORT=aegis-daily-report

S3_BUCKET_DATA=aegis-bucket-data

COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

AWS_REGION=ap-south-1
BEDROCK_REGION=us-east-1
