# Aegis-π Dashboard Web — environment variable template
# Copy this file to .env.local for local development.
# .env.local is gitignored. Do NOT commit real values.

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=https://api.aegis-pi.cloud

# WebSocket base URL (wss:// for production, ws:// for local)
VITE_WS_BASE_URL=wss://api.aegis-pi.cloud

# Cognito OIDC authority / issuer (no trailing slash)
# Use the User Pool issuer, not the Hosted UI domain.
VITE_COGNITO_AUTHORITY=https://cognito-idp.ap-south-1.amazonaws.com/<your-user-pool-id>

# Cognito Hosted UI domain (no trailing slash)
VITE_COGNITO_DOMAIN=https://kjw-aegis-data-auth.auth.ap-south-1.amazoncognito.com

# Cognito App Client ID (get from AWS Console → Cognito → App clients)
VITE_COGNITO_CLIENT_ID=<your-cognito-app-client-id>

# OAuth2 redirect URI (must match Cognito App Client callback URL setting)
# Production: https://dashboard.aegis-pi.cloud/callback
# Local dev:  http://localhost:5173/callback
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback

# Optional: post-logout redirect URI
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/
