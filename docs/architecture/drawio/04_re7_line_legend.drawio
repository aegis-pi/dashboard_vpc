        <mxCell id="title" value="Aegis-Pi Architecture 04 — Line Legend" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
